# ===========================================
# TRAFIKVERKET SLOT MONITOR CONFIGURATION
# ===========================================

# Booking portal URL (default is fine)
BOOKING_URL=https://fp.trafikverket.se/Boka/

# ===========================================
# BOOKING OPTIONS
# ===========================================
# License type: B (car), A (motorcycle), etc.
LICENSE_TYPE=B

# Exam type: Körprov (practical) or Kunskapsprov (theory)
EXAM_TYPE=Körprov

# Test location (must match exactly as shown on the website)
LOCATION=Göteborg-Hisingen

# Vehicle type: Automatbil or Manuell
VEHICLE_TYPE=Automatbil

# ===========================================
# FILTERS
# ===========================================
# Only show slots before this date (YYYY-MM-DD format)
# Leave empty to show all available slots
CHECK_BEFORE_DATE=2026-06-30

# Run browser in headless mode (true/false)
# Set to false for first-time login with BankID
HEADLESS=true

# ===========================================
# EMAIL NOTIFICATIONS (Gmail example)
# ===========================================
NOTIFICATION_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
SMTP_PASSWORD=your_app_password

# ===========================================
# TELEGRAM NOTIFICATIONS (optional)
# ===========================================
# 1. Create a bot with @BotFather
# 2. Get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# DISCORD NOTIFICATIONS (optional)
# ===========================================
# Create a webhook in Discord channel settings
DISCORD_WEBHOOK_URL=